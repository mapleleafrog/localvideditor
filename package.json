{
  "name": "soranji-vfx",
  "version": "1.0.0",
  "description": "Remotion (React -> MP4) VFX pipeline for the 'Soranji' wedding walk-in video. Comprehensive 2D / pixel-art effect registry with a depth (2.5D) system.",
  "repository": {},
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@remotion/cli": "4.0.472",
    "@remotion/gif": "4.0.472",
    "@remotion/media-utils": "4.0.472",
    "@remotion/paths": "4.0.472",
    "@remotion/player": "4.0.472",
    "@remotion/shapes": "4.0.472",
    "@remotion/studio": "4.0.472",
    "@remotion/transitions": "4.0.472",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.472"
  },
  "devDependencies": {
    "@remotion/eslint-config-flat": "4.0.472",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/web": "0.0.166",
    "@vitejs/plugin-react": "5.0.4",
    "eslint": "9.19.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "vite": "7.1.12"
  },
  "scripts": {
    "dev": "remotion studio",
    "editor": "vite --config editor/vite.config.mjs",
    "editor:build": "vite build --config editor/vite.config.mjs",
    "build": "remotion bundle",
    "render": "remotion render SoranjiSample out/soranji-sample.mp4",
    "render:timeline": "remotion render Timeline out/timeline.mp4",
    "credits": "node scripts/gen-credits.mjs",
    "typecheck": "tsc",
    "lint": "eslint src && tsc",
    "upgrade": "remotion upgrade"
  },
  "sideEffects": [
    "*.css"
  ]
}
